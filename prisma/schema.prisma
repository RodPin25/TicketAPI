// Configuración de conexión (Asegúrate que el provider sea sqlserver)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model Usuarios {
  idUser    Int      @id
  username  String   @unique // Cambiado a String
  password  String   // Cambiado a String
  type      Int
  tickets   Tickets[]
}

model Marca {
  idMarca          Int       @id
  nombreMarca      String    // Cambiado a String
  descripcionMarca String?   // Cambiado a String
  modelos          Modelos[]
}

model TipoVehiculo {
  idTipo          Int       @id
  nombreTipo      String    // Cambiado a String
  descripcionTipo String?   // Cambiado a String
  statusTipo      Int
  modelos         Modelos[]
}

model Modelos {
  idModelo     Int          @id
  nombreModelo String       // Cambiado a String
  idMarca      Int
  idTipo       Int
  marca        Marca        @relation(fields: [idMarca], references: [idMarca])
  tipoVehiculo TipoVehiculo @relation(fields: [idTipo], references: [idTipo])
  vehiculos    Vehiculos[]
}

model Vehiculos {
  placaVehiculo Int      @id
  idModelo      Int
  modelo        Modelos  @relation(fields: [idModelo], references: [idModelo])
  tickets       Tickets[]
}

model ConfiguracionCobro {
  idTipoCobro Int      @id
  tipoCobro   String   // Cambiado a String (ej: "Hora", "Día")
  montoCobro  Float    // Cambiado a Float/Decimal para dinero
  estadoCobro Int
  tickets     Tickets[]
}

model Tickets {
  idTicket          Int                @id
  statusTicket      Int
  montoTicket       Float              // Cambiado a Float para dinero
  horaEntrada       DateTime           // Cambiado a DateTime
  horaSalida        DateTime?          // Cambiado a DateTime (opcional si no ha salido)
  fechaEntrada      DateTime           @default(now())
  fechaSalida       DateTime?
  pagado            Int                // Puede ser 1 o 0
  fechaModificacion DateTime           @updatedAt
  idUser            Int
  placaVehiculo     Int
  idTipoCobro       Int
  
  usuario           Usuarios           @relation(fields: [idUser], references: [idUser])
  vehiculo          Vehiculos          @relation(fields: [placaVehiculo], references: [placaVehiculo])
  configuracion     ConfiguracionCobro @relation(fields: [idTipoCobro], references: [idTipoCobro])
}